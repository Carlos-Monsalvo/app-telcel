size = 4
) +
# 📊 Porcentaje dentro
geom_text(
aes(label = etiqueta_pct),
vjust = 1.5,
color = "black",
size = 4
) +
# 🎨 colores manuales (se adaptan al número de sucursales)
scale_fill_manual(
values = colorRampPalette(c(
"#146152",
"#44803F",
"#B4CF66",
"#FFEC5C",
"#FF5A33"
))(nrow(data_plot))
) +
labs(
title = "Distribución por Sucursal",
