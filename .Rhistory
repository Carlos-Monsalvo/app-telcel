)
) +
labs(title = "Ventas por Vendedor") +
theme_minimal() +
theme(
plot.title = element_text(hjust = 0.5),
legend.position = "none"
) +
expand_limits(y = max(data_plot$n) * 1.2)
}, height = function() {
n_vendedores <- length(unique(data$vendedor))
return(max(400, n_vendedores * 40))
})
# 🎯 SUCURSAL
output$sucursalPlot <- renderPlot({
data_plot <- data %>%
count(sucursal) %>%
mutate(
porcentaje = n / sum(n),
etiqueta_pct = scales::percent(porcentaje, accuracy = 1)
)
ggplot(data_plot, aes(sucursal, n, fill = sucursal)) +
geom_col(width = 0.7) +
# 🔢 Frecuencia arriba
geom_text(
aes(label = n),
vjust = -0.5,
size = 4
) +
# 📊 Porcentaje dentro
geom_text(
aes(label = etiqueta_pct),
vjust = 1.5,
color = "black",
size = 4
) +
# 🎨 colores manuales (se adaptan al número de sucursales)
scale_fill_manual(
values = colorRampPalette(c(
"#146152",
"#44803F",
"#B4CF66",
"#FFEC5C",
"#FF5A33"
))(nrow(data_plot))
) +
labs(
title = "Distribución por Sucursal",
x = "Sucursal",
y = "Frecuencia"
) +
theme_minimal() +
theme(
plot.title = element_text(hjust = 0.5),
legend.position = "none"
) +
expand_limits(y = max(data_plot$n) * 1.15)
})
# 🎯 VENTAS POR MES
output$ventasMesPlot <- renderPlot({
meses <- c("enero","febrero","marzo","abril","mayo","junio",
"julio","agosto","septiembre","octubre","noviembre","diciembre")
data_plot <- data %>%
group_by(mes, mes_nombre) %>%
summarise(ventas = sum(ventas), .groups = "drop") %>%
arrange(mes)
ggplot(data_plot, aes(x = mes, y = ventas)) +
geom_line(color = "#146152", linewidth = 1) +
geom_point(color = "#FF5A33", size = 2) +
# 🔢 valores en los puntos
geom_text(
aes(label = scales::comma(ventas)),
vjust = -0.8,
size = 3.5
) +
scale_x_continuous(
breaks = 1:12,
labels = meses
) +
labs(
title = "Ventas por Mes",
x = "Mes",
y = "Ventas"
) +
theme_minimal() +
theme(
plot.title = element_text(hjust = 0.5),
axis.text.x = element_text(angle = 45, hjust = 1)
) +
expand_limits(y = max(data_plot$ventas) * 1.1)
})
# 🎯 VENTAS POR AÑO
output$ventasAnioPlot <- renderPlot({
data_plot <- data %>%
group_by(año) %>%
summarise(ventas = sum(ventas), .groups = "drop") %>%
arrange(año)
ggplot(data_plot, aes(x = año, y = ventas)) +
geom_line(color = "#146152", linewidth = 1.2) +
geom_point(color = "#FF5A33", size = 3) +
# 🔢 etiquetas de valores
geom_text(
aes(label = scales::comma(ventas)),
vjust = -0.8,
size = 4
) +
labs(
title = "Ventas por Año",
x = "Año",
y = "Ventas"
) +
theme_minimal() +
theme(
plot.title = element_text(hjust = 0.5)
) +
expand_limits(y = max(data_plot$ventas) * 1.1)
})
}
shinyApp(ui, server)
set.seed(123)
library(dplyr)
library(lubridate)
n <- 1500
data <- data.frame(
fecha = seq.Date(Sys.Date()-1499, Sys.Date(), by="day")
)
data <- data %>%
mutate(
año = year(fecha),
mes = month(fecha),
dia_semana = weekdays(fecha),
idCliente = sample(10000:99999, n, replace = TRUE),
edad = sample(18:70, n, replace = TRUE),
genero = sample(c("Masculino","Femenino"), n, replace = TRUE),
tipoCliente = sample(c("Recargas","Planes"), n, replace = TRUE, prob = c(0.6,0.4)),
antiguedad_meses = sample(1:60, n, replace = TRUE),
tipoProducto = sample(c("Chip","Plan","Equipo"), n, replace = TRUE, prob = c(0.4,0.3,0.3)),
marcaEquipo = sample(c("Samsung","Apple","Xiaomi","Motorola","NA"), n, replace = TRUE),
modeloEquipo = paste("Modelo", sample(1:20, n, replace = TRUE)),
gama = sample(c("Baja","Media","Alta"), n, replace = TRUE, prob = c(0.4,0.4,0.2)),
ventas = round(runif(n, 100, 20000)),
costo = ventas * runif(n, 0.5, 0.8),
margen = ventas - costo,
metodoPago = sample(c("Efectivo","Tarjeta","Transferencia"), n, replace = TRUE),
vendedor = sample(paste("Vendedor", 1:10), n, replace = TRUE),
sucursal = sample(c("Norte","Centro","Sur","Oriente","Poniente"), n, replace = TRUE),
numeroCompras = sample(1:10, n, replace = TRUE),
frecuenciaCompra = round(runif(n, 0.1, 3),2),
descuento = round(runif(n, 0, 0.3),2)
)
# KPI derivados
data <- data %>%
mutate(
ticketPromedio = ventas / numeroCompras,
ROI = (ventas - costo) / costo
)
#Agregar columna de segmentacion de edad
data <- data %>%
mutate(
rango_edad = case_when(
edad >= 18 & edad <= 25 ~ "18-25",
edad >= 26 & edad <= 35 ~ "26-35",
edad >= 36 & edad <= 45 ~ "36-45",
edad >= 46 & edad <= 55 ~ "46-55",
edad >= 56 ~ "56+"
)
)
meses <- c("enero","febrero","marzo","abril","mayo","junio",
"julio","agosto","septiembre","octubre","noviembre","diciembre")
data <- data %>%
mutate(
mes_nombre = meses[mes]
)
####   Paleta de colores
#### Dashboard
library(shiny)
library(shinydashboard)
library(dplyr)
library(ggplot2)
library(lubridate)
ui <- dashboardPage(
dashboardHeader(title = "Dashboard Telcel"),
dashboardSidebar(
sidebarMenu(
menuItem("General", tabName = "general", icon = icon("chart-pie")),
menuItem("KPI", tabName = "kpi"),
menuItem("Series de tiempo", tabName = "series"),
menuItem("Segmentación", tabName = "segmentacion")
)
),
dashboardBody(
tabItems(
# ---------------- GENERAL ----------------
tabItem(tabName = "general",
fluidRow(
box(plotOutput("ventasMesPlot"), width = 6),
box(plotOutput("ventasAnioPlot"), width = 6)
),
fluidRow(
box(plotOutput("generoPlot"), width = 4),
box(plotOutput("edadPlot"), width = 4),
box(plotOutput("clientePlot"), width = 4)
),
fluidRow(
box(plotOutput("productoPlot"), width = 4),
box(plotOutput("vendedorPlot"), width = 4),
box(plotOutput("sucursalPlot"), width = 4)
)
)
)
)
)
server <- function(input, output) {
# 🎯 GENERO (pastel)
output$generoPlot <- renderPlot({
data %>%
count(genero) %>%
mutate(
porcentaje = n / sum(n),
etiqueta = scales::percent(porcentaje)
) %>%
ggplot(aes(x = 2, y = n, fill = genero)) +
geom_bar(stat = "identity", width = 1) +
coord_polar(theta = "y") +
xlim(0.5, 2.5) +  # dona
geom_text(aes(label = etiqueta),
position = position_stack(vjust = 0.5),
color = "white",
size = 5) +
scale_fill_manual(values = c(
"Masculino" = "#146152",
"Femenino" = "#FF5A33"
)) +
labs(
title = "Distribución por Género",
fill = "Género"   # 👈 esto deja la leyenda lateral
) +
theme_void() +
theme(
legend.position = "right",   # 👈 etiquetas laterales
plot.title = element_text(hjust = 0.5, size = 14)
)
})
# 🎯 EDAD (histograma)
output$edadPlot <- renderPlot({
data_plot <- data %>%
count(rango_edad) %>%
mutate(
porcentaje = n / sum(n),
etiqueta_pct = scales::percent(porcentaje, accuracy = 1)
)
ggplot(data_plot, aes(x = rango_edad, y = n, fill = rango_edad)) +
geom_col() +
# 🔢 Frecuencia arriba
geom_text(
aes(label = n),
vjust = -0.5,
size = 5
) +
# 📊 Porcentaje dentro
geom_text(
aes(label = etiqueta_pct),
vjust = 1.5,
color = "black",
size = 4
) +
scale_fill_manual(values = c(
"18-25" = "#146152",
"26-35" = "#44803F",
"36-45" = "#B4CF66",
"46-55" = "#FFEC5C",
"56+"   = "#FF5A33"
)) +
labs(
title = "Distribución por rango de edad",
x = "Rango de edad",
y = "Frecuencia"
) +
theme_minimal() +
theme(
plot.title = element_text(hjust = 0.5),
legend.position = "none"
) +
expand_limits(y = max(data_plot$n) * 1.15)
})
# 🎯 TIPO CLIENTE
output$clientePlot <- renderPlot({
data_plot <- data %>%
count(tipoCliente) %>%
mutate(
porcentaje = n / sum(n),
etiqueta_pct = scales::percent(porcentaje, accuracy = 1)
)
ggplot(data_plot, aes(tipoCliente, n, fill = tipoCliente)) +
geom_col(width = 0.7) +
# 🔢 Frecuencia arriba
geom_text(
aes(label = n),
vjust = -0.5,
size = 5
) +
# 📊 Porcentaje dentro
geom_text(
aes(label = etiqueta_pct),
vjust = 1.5,
color = "black",
size = 4
) +
scale_fill_manual(values = c(
"Recargas" ="#FFEC5C",
"Planes"   = "#FF5A33"
)) +
labs(
title = "Tipo de Cliente",
x = "Tipo de cliente",
y = "Frecuencia"
) +
theme_minimal() +
theme(
plot.title = element_text(hjust = 0.5),
legend.position = "none"
) +
expand_limits(y = max(data_plot$n) * 1.15)
})
# 🎯 TIPO PRODUCTO
output$productoPlot <- renderPlot({
data_plot <- data %>%
count(tipoProducto) %>%
mutate(
porcentaje = n / sum(n),
etiqueta_pct = scales::percent(porcentaje, accuracy = 1)
)
ggplot(data_plot, aes(reorder(tipoProducto, n), n, fill = tipoProducto)) +
geom_col(width = 0.7) +
# 🔢 Frecuencia arriba
geom_text(
aes(label = n),
vjust = -0.3,
size = 4
) +
# 📊 Porcentaje dentro
geom_text(
aes(label = etiqueta_pct),
vjust = 1.5,
color = "black",
size = 4
) +
scale_fill_manual(values = c(
"Chip"   ="#146152",
"Plan"   = "#44803F",
"Equipo" = "#B4CF66"
)) +
labs(
title = "Tipo de Producto",
x = "Producto",
y = "Cantidad"
) +
theme_minimal() +
theme(
plot.title = element_text(hjust = 0.5),
legend.position = "none"
) +
expand_limits(y = max(data_plot$n) * 1.15)
})
# 🎯 VENDEDOR
output$vendedorPlot <- renderPlot({
data_plot <- data %>%
count(vendedor) %>%
arrange(n) %>%  # 🔥 orden ascendente
mutate(
porcentaje = n / sum(n),
etiqueta_pct = scales::percent(porcentaje, accuracy = 1),
orden = row_number()  # 🔥 clave para gradiente
)
ggplot(data_plot, aes(reorder(vendedor, n), n, fill = orden)) +
geom_col(width = 0.9) +
coord_flip() +
# 🔢 Frecuencia
geom_text(aes(label = n), hjust = -0.2, size = 4) +
# 📊 %
geom_text(aes(label = etiqueta_pct),
hjust = 1.2,
color = "white",
size = 3.5) +
# 🎨 GRADIENTE REAL
scale_fill_gradientn(
colors = c(
"#146152",
"#44803F",
"#B4CF66",
"#FFEC5C",
"#FF5A33"
)
) +
labs(title = "Ventas por Vendedor") +
theme_minimal() +
theme(
plot.title = element_text(hjust = 0.5),
legend.position = "none"
) +
expand_limits(y = max(data_plot$n) * 1.2)
}, height = function() {
n_vendedores <- length(unique(data$vendedor))
return(max(400, n_vendedores * 40))
})
# 🎯 SUCURSAL
output$sucursalPlot <- renderPlot({
data_plot <- data %>%
count(sucursal) %>%
mutate(
porcentaje = n / sum(n),
etiqueta_pct = scales::percent(porcentaje, accuracy = 1)
)
ggplot(data_plot, aes(sucursal, n, fill = sucursal)) +
geom_col(width = 0.7) +
# 🔢 Frecuencia arriba
